# JIP Horizon India — Environment Variables
# Copy this to .env and fill in your values

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# Anthropic Claude (required for thesis generation, optional for scoring)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Screener.in (optional — needed for financial history fetch)
# Get this: screener.in → Login → F12 → Application → Cookies → sessionid
SCREENER_SESSION_COOKIE=

# App config (defaults are fine)
ENVIRONMENT=development
PORT=8002
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_DAILY_BUDGET_USD=0.30

# API config
APP_VERSION=0.1.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
